generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  firstName String
  lastName  String
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneratedCodes {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  code      String   @unique
  status    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String?
}

model Staff {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  email          String          @unique
  firstName      String
  lastName       String
  state          String
  takenTest      Boolean         @default(false)
  testsTaken     String[]        @default([])          // Array of strings with default empty array
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?
  password       String?

  coupon         ShopifyCoupon?  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId       String?         @unique @db.ObjectId

  inviteCode     InviteCode?     @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  inviteCodeId   String?         @unique @db.ObjectId
}

model ShopifyCoupon {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff     Staff?   @relation
}

model InviteCode {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  code         String   @unique
  status       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staff        Staff?   @relation
}

